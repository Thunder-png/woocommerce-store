        "Order": {
            "required": [
                "referenceId",
                "shipmentServiceType",
                "packagingType",
                "content",
                "smsPreference1",
                "smsPreference2",
                "smsPreference3",
                "paymentType",
                "deliveryType",
                "description"
            ],
            "type": "object",
            "properties": {
                "referenceId": {
                    "description": "Identity Number of Order, ReferenceId must be unique foreach order. ReferenceId must be uppercase.\r\nSipari\u015f Numaras\u0131, Sipari\u015f numaras\u0131 her sipari\u015f i\u00e7in benzersiz olmal\u0131d\u0131r. Sipari\u015f numaras\u0131 b\u00fcy\u00fckharflerden olu\u015fmal\u0131d\u0131r.",
                    "type": "string"
                },
                "barcode": {
                    "description": "Barcode must be same with ReferenceId. Barcode must be uppercase.\r\nBarkod ReferenceId ile ayn\u0131 olmal\u0131d\u0131r. Barkod b\u00fcy\u00fckharflerden olu\u015fmal\u0131d\u0131r.",
                    "type": "string"
                },
                "billOfLandingId": {
                    "description": "Bill Of LandingId\r\n\u0130rsaliye Numaras\u0131",
                    "type": "string"
                },
                "isCOD": {
                    "format": "int32",
                    "description": "Indicates whether it is Cash On Delivery.\r\nKap\u0131da \u00d6deme mi?",
                    "type": "integer"
                },
                "codAmount": {
                    "format": "double",
                    "description": "Cash on Delivery Amount\r\nKap\u0131da \u00d6deme Miktar\u0131",
                    "type": "number"
                },
                "shipmentServiceType": {
                    "format": "int32",
                    "description": "Shipment Service Type: 1:STANDART_TESL\u0130MAT, 7:GUN\u0130C\u0130_TESL\u0130MAT, 8:AK\u015eAM_TESL\u0130MAT\r\nG\u00f6nderi Tipi",
                    "type": "integer"
                },
                "packagingType": {
                    "format": "int32",
                    "description": "Package Type of Order:  1:DOSYA, 2:M\u0130, 3:PAKET, 4:KOL\u0130\r\nKargo Cinsi",
                    "type": "integer"
                },
                "content": {
                    "description": "Content\r\nGenel \u0130\u00e7erik Bilgisi",
                    "type": "string"
                },
                "smsPreference1": {
                    "format": "int32",
                    "description": "SMSPreference Is Send SMS to Recipient When Shipment Reached to Destination Branch\r\nKargo var\u0131\u015f \u015fubesine ula\u015ft\u0131\u011f\u0131nda al\u0131c\u0131ya SMS gitsin mi?",
                    "type": "integer"
                },
                "smsPreference2": {
                    "format": "int32",
                    "description": "Is Send SMS to Recipient When Shpiment First Prepare\r\nKargo ilk haz\u0131rland\u0131\u011f\u0131nda al\u0131c\u0131ya SMS gitsin mi?",
                    "type": "integer"
                },
                "smsPreference3": {
                    "format": "int32",
                    "description": "Is Send SMS to Shipper When Shipment Delivered\r\nKargo teslim edildi\u011finde g\u00f6ndericiye SMS gitsin mi?",
                    "type": "integer"
                },
                "paymentType": {
                    "format": "int32",
                    "description": "Payment Type of Order: 1:GONDERICI_ODER, 2:ALICI_ODER,3:PLATFORM_ODER. Method CreateOrder does not apply to payment type 3. \r\n\u00d6deme \u015eekli, CreateOrder metodunda 3 tipindeki \u00f6deme \u015fekli ge\u00e7erli de\u011fildir.",
                    "type": "integer"
                },
                "deliveryType": {
                    "format": "int32",
                    "description": "Delivery Type of Order: 1:ADRESE_TESLIM, 2:ALICISI_HABERL\u0130 \r\nTeslim \u015eekli",
                    "type": "integer"
                },
                "description": {
                    "type": "string"
                },
                "marketPlaceShortCode": {
                    "description": "Short MarketPlace Code of Order : ex: TRND, N11, GG, VIVE\r\nPazaryeri Kodu  \u00f6rne\u011fin: TRND, N11, GG, VIVE",
                    "type": "string"
                },
                "marketPlaceSaleCode": {
                    "description": "Sale Code of MarketPlace\r\nPazaryeri Sat\u0131\u015f Kodu",
                    "type": "string"
                }
            }
        },
