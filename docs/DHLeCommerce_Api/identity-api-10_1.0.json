{
    "swagger": "2.0",
    "info": {
        "version": "1.0",
        "title": "Identity API",
        "description": "Di\u011fer API'leri kullanabilmek i\u00e7in, kimliklendirme yetkilendirme sa\u011flar.|Provides authentication and authorization to use other APIs.",
        "termsOfService": "http://swagger.io/terms/"
    },
    "paths": {
        "/token": {
            "post": {
                "tags": [
                    "User"
                ],
                "summary": "Generate Token",
                "description": "Api'lerimizi kullanabilmeniz i\u00e7in JWT Token gerekmektedir. | JWT Token is required to use our APIs.",
                "operationId": "TokenPost",
                "consumes": [
                    "application/json-patch+json",
                    "application/json",
                    "text/json",
                    "application/*+json"
                ],
                "produces": [
                    "application/json"
                ],
                "parameters": [
                    {
                        "name": "request",
                        "in": "body",
                        "required": false,
                        "schema": {
                            "$ref": "#/definitions/GenerateTokenRequest"
                        }
                    },
                    {
                        "name": "x-api-version",
                        "in": "header",
                        "required": false,
                        "type": "string"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Success",
                        "schema": {
                            "$ref": "#/definitions/GenerateTokenResponseExample"
                        },
                        "examples": {
                            "application/json": {
                                "jwt": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiIxMjM0NTY3ODkwIiwibmFtZSI6IkpvaG4gRG9lIiwiaWF0IjoxNTE2MjM5MDIyfQ.SflKxwRJSMeKKF2QT4fwpMeJf36POk6yJV_adQssw5c",
                                "refreshToken": "f41c92bf-cc20-491b-9e4c-efc1b253e43a",
                                "jwtExpireDate": "10.03.2020 16:05:00",
                                "refreshTokenExpireDate": "09.04.2020 15:04:31"
                            }
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/ProblemDetails"
                        }
                    },
                    "401": {
                        "description": "Unauthorized"
                    },
                    "500": {
                        "description": "Server Error"
                    }
                }
            }
        }
    },
    "definitions": {
        "GenerateTokenRequest": {
            "required": [
                "customerNumber",
                "password",
                "identityType"
            ],
            "type": "object",
            "properties": {
                "customerNumber": {
                    "description": "Number of MNG Customer \r\nMNG M\u00fc\u015fteri Numaras\u0131",
                    "type": "string"
                },
                "password": {
                    "description": "Password of MNG Customer \r\nMNG M\u00fc\u015fteri \u015eifresi",
                    "type": "string"
                },
                "identityType": {
                    "format": "int32",
                    "description": "Identity Type of Customer, for default set 1. \r\nM\u00fc\u015fteri kimlik tipi varsay\u0131lan olarak 1'e setleyiniz.",
                    "type": "integer"
                }
            },
            "example": {
                "customerNumber": "312947702",
                "password": "ABCD1234",
                "identityType": 1
            }
        },
        "GenerateTokenResponseExample": {
            "type": "object",
            "properties": []
        },
        "ProblemDetails": {
            "type": "object",
            "properties": {
                "type": {
                    "type": "string"
                },
                "title": {
                    "type": "string"
                },
                "status": {
                    "format": "int32",
                    "type": "integer"
                },
                "detail": {
                    "type": "string"
                },
                "instance": {
                    "type": "string"
                }
            },
            "additionalProperties": {
                "type": "object"
            }
        }
    },
