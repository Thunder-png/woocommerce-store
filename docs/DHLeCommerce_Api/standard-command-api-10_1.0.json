{
    "swagger": "2.0",
    "info": {
        "version": "1.0",
        "title": "Standard Command API",
        "description": "'Normal', '\u0130ade' sipari\u015fleri olu\u015fturan, sipari\u015fi g\u00fcncelleyen ve sipari\u015fi iptal eden metodlar\u0131n bulundu\u011fu API'dir. |This API inculdes methods that creates Normal, Return types of order, updates order and cancels order.",
        "termsOfService": "http://swagger.io/terms/"
    },
    "basePath": "/mngapi/api/standardcmdapi",
    "paths": {
        "/createOrder": {
            "post": {
                "tags": [
                    "StandardCommand"
                ],
                "summary": "Create Order",
                "description": "'Normal' sipari\u015f olu\u015fturur. Al\u0131c\u0131 bilgisi de\u011ferleri doldurulurken ya CustomerId verilir ya da Al\u0131c\u0131 FullName, CityCode, DistrictCode, Address alanlar\u0131 ve MobilePhoneNumber, HomePhoneNumber, BussinessPhoneNumber'dan herhangi biri girilmelidir. | Creates normal type of order. When you fill Recipient areas either you set CustomerId or Recipient' s FullName, CityCode, DistrictCode, Address and one of the MobilePhoneNumber, HomePhoneNumber, BussinessPhoneNumber.",
                "operationId": "CreateOrderPost",
                "consumes": [
                    "application/json-patch+json",
                    "application/json",
                    "text/json",
                    "application/*+json"
                ],
                "produces": [
                    "application/json"
                ],
                "parameters": [
                    {
                        "name": "createOrderRequest",
                        "in": "body",
                        "required": false,
                        "schema": {
                            "$ref": "#/definitions/CreateOrderRequest"
                        }
                    },
                    {
                        "name": "x-api-version",
                        "in": "header",
                        "required": false,
                        "type": "string"
                    },
                    {
                        "name": "Authorization",
                        "in": "header",
                        "description": "JWT Authorization header using the Bearer scheme. Example: \"Authorization: Bearer {token}\"",
                        "required": true,
                        "type": "string"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Order created",
                        "schema": {
                            "$ref": "#/definitions/CreateOrderResponse"
                        },
                        "examples": {
                            "application/json": {
                                "orderInvoiceId": "456764543",
                                "orderInvoiceDetailId": "25423565",
                                "shipperBranchCode": "1345",
                                "referenceId": "YourReferenceId"
                            }
                        }
                    },
                    "400": {
                        "description": "Bad Request"
                    },
                    "401": {
                        "description": "Unauthorized"
                    },
                    "500": {
                        "description": "Server Error"
                    }
                }
            }
        },
        "/createReturnOrder": {
