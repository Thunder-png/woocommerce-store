            "type": "object",
            "properties": {
                "referenceId": {
                    "description": "Identity Number of Order, ReferenceId must be unique foreach order. ReferenceId must be uppercase.\r\nSipari\u015f Numaras\u0131, Sipari\u015f numaras\u0131 her sipari\u015f i\u00e7in benzersiz olmal\u0131d\u0131r. Sipari\u015f numaras\u0131 b\u00fcy\u00fckharflerden olu\u015fmal\u0131d\u0131r.",
                    "type": "string"
                },
                "barcode": {
                    "description": "Barcode must be same with ReferenceId. Barcode must be uppercase.\r\nBarkod ReferenceId ile ayn\u0131 olmal\u0131d\u0131r. Barkod b\u00fcy\u00fckharflerden olu\u015fmal\u0131d\u0131r.",
                    "type": "string"
